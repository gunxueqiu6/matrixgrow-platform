﻿# ========== 必填 ==========
# JWT 签名密钥
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# 数据库路径
DB_PATH=./data/matrixgrow.db

# ========== LLM 模型 ==========
# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# 通义千问
QWEN_API_KEY=your-qwen-key

# ========== 支付 ==========
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_MCH_KEY=your-wechat-merchant-key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/callback

ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/callback
ALIPAY_RETURN_URL=https://your-domain.com/payment/result

# ========== 平台 API Key ==========
AYRSHARE_API_KEY=your-ayrshare-key
DEVTO_API_KEY=your-devto-key

# ========== 部署 ==========
PORT=3000
BASE_URL=http://localhost:3000
ENABLE_MONITOR=false
PLAYWRIGHT_HEADLESS=true
